def fetch_json(base, name, refresh):
    cache = os.path.join(CACHE_DIR, name.replace("/", "-"))
    has_cache = os.path.exists(cache)
    if not refresh and has_cache and time.time() - os.path.getmtime(cache) < TTL:
        with open(cache, encoding="utf-8") as f:
            return json.load(f)
    url = base.rstrip("/") + "/" + name
    headers = {"User-Agent": "zhiku-cli/0.4"}
    if has_cache:
        headers["If-Modified-Since"] = time.strftime(
            "%a, %d %b %Y %H:%M:%S GMT", time.gmtime(os.path.getmtime(cache))
        )
    req = urllib.request.Request(url, headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=60) as r:
            data = json.loads(r.read().decode("utf-8"))
    except urllib.error.HTTPError as exc:
        if exc.code == 304 and has_cache:
            os.utime(cache, None)
            with open(cache, encoding="utf-8") as f:
                return json.load(f)
        raise
    os.makedirs(CACHE_DIR, exist_ok=True)
    with open(cache, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False)
    return data


