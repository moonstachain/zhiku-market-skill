def _file_sha256(path):
    try:
        return hashlib.sha256(path.read_bytes()).hexdigest()
    except OSError:
        return ""


def _git_read(root, *args):
    result = subprocess.run(
        ["git", "-C", str(root), *args],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    return {
        "returncode": result.returncode,
        "stdout": result.stdout.strip(),
        "stderr": result.stderr.strip(),
    }


def _block_authoring_core(reason):
    raise SystemExit(f"{AUTHORING_CORE_BLOCKER}:{reason}")


def _trusted_authoring_core(runtime_root):
    governor_home = Path(
        os.environ.get(
            "ZHIKU_GOVERNOR_HOME",
            Path.home() / ".local/share/zhiku-skill-governor",
        )
    ).expanduser()
    receipt_path = governor_home / "automation/daily-install-receipt.json"
    try:
        receipt = json.loads(receipt_path.read_text(encoding="utf-8"))
        metadata = json.loads((runtime_root / "runtime-metadata.json").read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        _block_authoring_core("install_receipt_or_runtime_metadata_missing")
    if not (
        receipt.get("schema") == "zhiku_skill_governor_daily_install_receipt_v2"
        and receipt.get("status") == "installed"
        and receipt.get("source_dirty") is False
        and receipt.get("external_writes") is False
    ):
        _block_authoring_core("install_receipt_not_trusted")
    commit = str(metadata.get("commit") or "")
    if not commit or receipt.get("commit") != commit:
        _block_authoring_core("install_receipt_commit_mismatch")
    try:
        installed_runtime = Path(str(receipt.get("runtime") or "")).expanduser().resolve()
    except OSError:
        _block_authoring_core("install_receipt_runtime_invalid")
    if installed_runtime != runtime_root.resolve():
        _block_authoring_core("install_receipt_runtime_mismatch")
    core_root = Path(str(receipt.get("core_root") or "")).expanduser()
    engine = core_root / "systems/zhiku/forge/skill_governor.py"
    runtime_engine = runtime_root / "systems/zhiku/forge/skill_governor.py"
    if not engine.is_file() or not runtime_engine.is_file():
        _block_authoring_core("authoring_engine_missing")
    head = _git_read(core_root, "rev-parse", "HEAD")
    if head["returncode"] != 0:
        _block_authoring_core("authoring_commit_query_failed")
    if head["stdout"] != commit:
        _block_authoring_core("authoring_commit_mismatch")
    status = _git_read(
        core_root,
        "status",
        "--porcelain",
        "--untracked-files=all",
    )
    if status["returncode"] != 0:
        _block_authoring_core("authoring_status_query_failed")
    if status["stdout"]:
        _block_authoring_core("authoring_worktree_dirty")
    engine_hash = _file_sha256(engine)
    if not engine_hash or engine_hash != _file_sha256(runtime_engine):
        _block_authoring_core("authoring_engine_hash_mismatch")
    if receipt.get("engine_hash") != engine_hash or metadata.get("engine_hash") != engine_hash:
        _block_authoring_core("authoring_engine_attestation_mismatch")
    return core_root.resolve()


def private_core_root():
    try:
        runtime_or_core = Path(__file__).resolve().parents[4]
    except IndexError:
        _block_authoring_core("entrypoint_root_unknown")
    configured = os.environ.get("ZHIKU_CORE_ROOT")
    if configured:
        root = Path(configured).expanduser().resolve()
        if not (root / "systems/zhiku/forge/skill_governor.py").is_file():
            _block_authoring_core("configured_core_invalid")
        if (runtime_or_core / "runtime-metadata.json").is_file():
            trusted = _trusted_authoring_core(runtime_or_core)
            if root != trusted:
                _block_authoring_core("configured_core_not_attested")
        return root
    if (runtime_or_core / "runtime-metadata.json").is_file():
        return _trusted_authoring_core(runtime_or_core)
    if not (runtime_or_core / "systems/zhiku/forge/skill_governor.py").is_file():
        _block_authoring_core("private_control_plane_unavailable")
    return runtime_or_core

