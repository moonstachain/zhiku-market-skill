STOP = re.compile(r"^(我要|我想|想要|帮我|请帮|帮忙|给我|怎么|如何|有没有|哪个|什么|一个|一份|一篇|一条|需要|用来|可以|能不能|做个|做一个|搞个|弄个|请问)")


def fetch_catalog(base, refresh):
    if not refresh and os.path.exists(CACHE) and time.time() - os.path.getmtime(CACHE) < TTL:
        with open(CACHE, encoding="utf-8") as f:
            return json.load(f)
    url = base.rstrip("/") + "/catalog.json"
    req = urllib.request.Request(url, headers={"User-Agent": "zhiku-cli/0.1"})
    with urllib.request.urlopen(req, timeout=60) as r:
        data = json.loads(r.read().decode("utf-8"))
    os.makedirs(os.path.dirname(CACHE), exist_ok=True)
    with open(CACHE, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False)
    return data


def tokenize(q):
    en = [w for w in re.findall(r"[a-z0-9][a-z0-9_\-.]+", q.lower()) if len(w) >= 2]
    zh = re.sub(r"[a-zA-Z0-9_\-./]+", " ", q)
    segs = []
    for s in re.split(r"[^一-鿿]+", zh):
        if not s:
            continue
        prev = None
        while prev != s and s:
            prev, s = s, STOP.sub("", s)
        if len(s) >= 2:
            segs.append(s)
    grams = sorted({s[i:i + 2] for s in segs for i in range(len(s) - 1)})
    ex = sorted({w for s in segs for k, ws in ZH2EN.items() if k in s for w in ws} - set(en))
    return en, segs, grams, ex


def score_all(q, catalog, only_type=None):
    en, segs, grams, ex = tokenize(q)
    res = []
    for t in TYPES:
        if only_type and t != only_type:
            continue
        for it in catalog.get(t, []):
            name = (it.get("name") or "").lower()
            cat = (it.get("category") or "").lower()
            desc = (it.get("description") or "").lower()
            sc, hits = 0.0, 0
            for words, w in ((en, 1), (grams, 1), (segs, 1.5), (ex, 0.8)):
                for tok in words:
                    h = (5 if tok in name else 0) + (2 if tok in cat else 0) + (1 if tok in desc else 0)
                    if h:
                        sc += h * w
                        hits += 1
            if sc <= 0:
                continue
            sc += hits * 2
            if it.get("mine"):
                sc *= 1.5
            sc += math.log10((it.get("downloads") or 0) + 1) * 0.3
            res.append((sc, t, it))
    res.sort(key=lambda x: -x[0])
    return res


def install_cmd(t, it):
    p = re.sub(r"\.(md|json)$", "", it.get("path") or it.get("name") or "")
    return f"npx claude-code-templates@latest {FLAGS[t]} {p} --yes"


def main():
    args = sys.argv[1:]
    base, only_type, top, as_json, refresh = BASE, None, 10, False, False
    q = []
    i = 0
    while i < len(args):
        a = args[i]
        if a in ("-t", "--type"):
            only_type = args[i + 1]; i += 2
        elif a in ("-n", "--top"):
            top = int(args[i + 1]); i += 2
        elif a == "--base":
            base = args[i + 1]; i += 2
        elif a == "--json":
            as_json = True; i += 1
        elif a == "--refresh":
            refresh = True; i += 1
        elif a in ("-h", "--help"):
            print(__doc__); return
        else:
            q.append(a); i += 1
    if not q:
        print(__doc__); sys.exit(1)
    if only_type and only_type not in TYPES:
        sys.exit(f"未知类型 {only_type}，可选: {'/'.join(TYPES)}")
    query = " ".join(q)
    catalog = fetch_catalog(base, refresh)
    hits = score_all(query, catalog, only_type)[:top]
    if as_json:
        print(json.dumps([{"score": round(s, 2), "type": t, "name": it.get("name"),
                           "category": it.get("category"), "mine": it.get("mine", 0),
                           "description": it.get("description", ""), "install": install_cmd(t, it)}
                          for s, t, it in hits], ensure_ascii=False, indent=1))
        return
    if not hits:
        print("没匹配到组件——换个说法试试（中文领域词或英文关键词，如 video / wechat / database）")
        return
    built = (catalog.get("_meta") or {}).get("built", "?")
    print(f"随身智库 · 组件市场 — \"{query}\" top {len(hits)}（数据 {built}）\n")
    for s, t, it in hits:
        star = " ★私有(需仓权限)" if it.get("mine") else ""
        desc = re.sub(r"\s+", " ", it.get("description") or "").strip()[:100]
        print(f"  {it.get('name')}  〔{t}·{it.get('category','—')}〕{star}")
        print(f"    {desc}")
        print(f"    $ {install_cmd(t, it)}\n")


if __name__ == "__main__":
    main()
