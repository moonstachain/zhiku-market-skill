def normalize_recipe(recipe):
    if not isinstance(recipe, dict):
        raise ValueError("operation_recipe_v1 must be a JSON object")
    out = dict(recipe)
    out.setdefault("schema", "operation_recipe_v1")
    out.setdefault("executor", "ego-browser")
    out.setdefault("permission_level", "inspect")
    out.setdefault("planned_steps", [])
    out.setdefault("checkpoints", [])
    out.setdefault("rollback_note", "No external write should be made without a fresh human gate.")
    out.setdefault("risk_tags", [])
    out.setdefault("component_path", None)
    missing = [k for k in ("intent", "target_url") if not out.get(k)]
    if missing:
        raise ValueError("recipe missing required field(s): " + ", ".join(missing))
    if out.get("executor") != "ego-browser":
        raise ValueError("only executor=ego-browser is supported in v1")
    if out.get("permission_level") not in PERMISSION_LEVELS:
        raise ValueError("permission_level must be one of: " + ", ".join(PERMISSION_LEVELS))
    if not re.match(r"^https?://", str(out.get("target_url"))):
        raise ValueError("target_url must be an http(s) URL")
    if not isinstance(out.get("planned_steps"), list):
        raise ValueError("planned_steps must be a list")
    if not isinstance(out.get("checkpoints"), list):
        raise ValueError("checkpoints must be a list")
    if not isinstance(out.get("risk_tags"), list):
        raise ValueError("risk_tags must be a list")
    return out


def _sensitive_hash(value):
    return hashlib.sha256(str(value or "").encode("utf-8")).hexdigest()


def _safe_url_origin(value):
    try:
        parsed = urllib.parse.urlsplit(str(value or ""))
        if not parsed.scheme or not parsed.hostname:
            return "redacted"
        host = parsed.hostname
        if ":" in host and not host.startswith("["):
            host = f"[{host}]"
        port = f":{parsed.port}" if parsed.port else ""
        return f"{parsed.scheme}://{host}{port}"
    except Exception:
        return "redacted"


def receipt_safe_recipe(recipe):
    target = recipe.get("target_url")
    intent = recipe.get("intent")
    component_path = recipe.get("component_path")
    source_intent_hash = str(recipe.get("source_intent_hash") or "")
    if not re.fullmatch(r"[0-9a-f]{64}", source_intent_hash, re.I):
        source_intent_hash = _sensitive_hash(source_intent_hash) if source_intent_hash else None
    safe = {
        "schema": "operation_recipe_v1",
        "executor": recipe.get("executor"),
        "permission_level": recipe.get("permission_level"),
        "allow_apply": recipe.get("allow_apply") is True,
        "apply_implemented": recipe.get("apply_implemented") is True,
        "static_h5_executes_browser": recipe.get("static_h5_executes_browser") is True,
        "receipt_redaction": "wechat_agent" if recipe.get("receipt_redaction") == "wechat_agent" else "default",
        "source_intent_hash": source_intent_hash,
        "planned_step_count": len(recipe.get("planned_steps") or []),
        "checkpoint_count": len(recipe.get("checkpoints") or []),
        "risk_tag_count": len(recipe.get("risk_tags") or []),
        "component_ref_hash": _sensitive_hash(component_path) if component_path else None,
    }
    safe["target_url"] = _safe_url_origin(target)
    safe["target_url_hash"] = _sensitive_hash(target)
    safe["intent_hash"] = _sensitive_hash(intent)
    safe["intent_length"] = len(str(intent or ""))
    fields = recipe.get("draft_fields") or []
    if fields:
        safe["draft_field_hashes"] = [
            {"selector_hash": _sensitive_hash(field.get("selector")), "value_hash": _sensitive_hash(field.get("value"))}
            for field in fields if isinstance(field, dict)
        ]
    return safe


def _safe_blocker(value):
    text = str(value or "")
    if re.fullmatch(r"[a-z0-9_:-]{1,120}", text):
        return text
    return "opaque_error:" + _sensitive_hash(text)[:16]


def redact_operation_receipt(receipt):
    receipt["target_url_hash"] = _sensitive_hash(receipt.get("target_url"))
    receipt["target_url"] = _safe_url_origin(receipt.get("target_url"))
    intent = receipt.pop("intent", "")
    receipt["intent_hash"] = _sensitive_hash(intent)
    receipt["intent_length"] = len(str(intent or ""))
    component_path = receipt.pop("component_path", None)
    receipt["component_ref_hash"] = _sensitive_hash(component_path) if component_path else None
    task_space_id = receipt.pop("task_space_id", None)
    receipt["task_space_id_hash"] = _sensitive_hash(task_space_id) if task_space_id else None
    receipt["observations"] = [
        {
            "type": _safe_blocker(row.get("type") or "observation"),
            "value_hash": _sensitive_hash(row.get("value")),
            "value_length": len(str(row.get("value") or "")),
        }
        for row in (receipt.get("observations") or []) if isinstance(row, dict)
    ]
    cleaned_actions = []
    for row in receipt.get("actions_taken") or []:
        if not isinstance(row, dict):
            continue
        clean = {
            "type": _safe_blocker(row.get("type") or "action"),
            "submitted": row.get("submitted") is True,
            "keep": row.get("keep") is True,
        }
        if row.get("selector"):
            clean["selector_hash"] = _sensitive_hash(row["selector"])
        cleaned_actions.append(clean)
    receipt["actions_taken"] = cleaned_actions
    receipt["blockers"] = [_safe_blocker(value) for value in receipt.get("blockers") or []]
    receipt["handoff_events"] = [
        {
            "type": _safe_blocker(row.get("type") or "handoff"),
            "reason_hash": _sensitive_hash(row.get("reason")),
        }
        for row in receipt.get("handoff_events") or []
        if isinstance(row, dict)
    ]
    receipt["evidence_paths"] = [f"operate:{receipt.get('run_id')}"]
    receipt["raw_observations_stored"] = False
    receipt["local_paths_stored"] = False
    receipt["raw_conversation_stored"] = False
    return receipt


