def run_ego_operation(recipe, receipt):
    permission = recipe.get("permission_level")
    if permission == "publish_or_pay":
        receipt["status"] = "blocked_human_gate"
        receipt["blockers"].append("publish_or_pay_requires_manual_handoff")
        receipt["handoff_events"].append({
            "type": "required_before_execution",
            "reason": "publish/pay/delete/external-send operations are never automated in v1",
        })
        return receipt
    if permission == "apply":
        receipt["status"] = "blocked_apply_not_implemented"
        receipt["blockers"].append("apply_requires_typed_actions_reversible_executor_and_verification_receipt")
        return receipt

    draft_fields = recipe.get("draft_fields") if isinstance(recipe.get("draft_fields"), list) else []
    task_name = f"zhiku:{receipt['run_id']}:{short_slug(recipe.get('intent'))}"
    js_recipe = json.dumps(recipe, ensure_ascii=False)
    js = f"""
const recipe = {js_recipe};
const task = await useOrCreateTaskSpace({json.dumps(task_name)});
const receipt = {{
  task_space_id: task.id,
  observations: [],
  actions_taken: [],
  handoff_events: [],
  blockers: []
}};
try {{
  await openOrReuseTab(recipe.target_url, {{ wait: true, timeout: 30 }});
  const info = await pageInfo();
  receipt.observations.push({{type: "page_info", value: info}});
  if (info && info.dialog) {{
    receipt.blockers.push("browser_dialog_open");
  }} else {{
    const snap = await snapshotText();
    receipt.observations.push({{type: "snapshot_head", value: String(snap || "").slice(0, 1800)}});
  }}
  if (recipe.permission_level === "draft" && Array.isArray(recipe.draft_fields)) {{
    for (const field of recipe.draft_fields) {{
      if (!field || !field.selector || field.value == null) continue;
      await fillInput(String(field.selector), String(field.value));
      receipt.actions_taken.push({{type: "fillInput", selector: String(field.selector), submitted: false}});
    }}
    const after = await snapshotText();
    receipt.observations.push({{type: "draft_verify_snapshot_head", value: String(after || "").slice(0, 1200)}});
  }}
  await completeTaskSpace(task.id, {{ keep: false }});
  receipt.actions_taken.push({{type: "completeTaskSpace", keep: false}});
  cliLog(JSON.stringify(receipt));
}} catch (err) {{
  receipt.blockers.push(String(err && err.message || err));
  try {{ await completeTaskSpace(task.id, {{ keep: false }}); }} catch (closeErr) {{}}
  cliLog(JSON.stringify(receipt));
}}
"""
    proc = subprocess.run(["ego-browser", "nodejs"], input=js, text=True, capture_output=True, timeout=90)
    combined_output = "\n".join(x for x in (proc.stdout, proc.stderr) if x)
    if proc.returncode != 0:
        receipt["status"] = "failed"
        receipt["blockers"].append(combined_output.strip() or f"ego-browser exited {proc.returncode}")
        return receipt
    lines = [ln.strip() for ln in combined_output.splitlines() if ln.strip()]
    payload = None
    for line in reversed(lines):
        try:
            payload = json.loads(line)
            break
        except Exception:
            continue
    if not payload:
        receipt["status"] = "failed"
        receipt["blockers"].append("ego_browser_no_json_receipt")
        if combined_output.strip():
            receipt["observations"].append({"type": "ego_output", "value": combined_output[-2000:]})
        return receipt
    receipt["task_space_id"] = payload.get("task_space_id")
    receipt["observations"].extend(payload.get("observations") or [])
    receipt["actions_taken"].extend(payload.get("actions_taken") or [])
    receipt["handoff_events"].extend(payload.get("handoff_events") or [])
    receipt["blockers"].extend(payload.get("blockers") or [])
    receipt["status"] = "completed" if not receipt["blockers"] else "blocked_needs_user"
    return receipt


