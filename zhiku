def tokenize(q):
    en = [w for w in re.findall(r"[a-z0-9][a-z0-9_\-.]+", q.lower()) if len(w) >= 2]
    zh = re.sub(r"[a-zA-Z0-9_\-./]+", " ", q)
    segs = []
    for s in re.split(r"[^一-鿿]+", zh):
        if not s:
            continue
        prev = None
        while prev != s and s:
            prev, s = s, STOP.sub("", s)
        if len(s) >= 2:
            segs.append(s)
    grams = sorted({s[i:i + 2] for s in segs for i in range(len(s) - 1)})
    ex = sorted({w for s in segs for k, ws in ZH2EN.items() if k in s for w in ws} - set(en))
    return en, segs, grams, ex


def infer_type(q):
    """Infer component type from explicit user wording. Explicit -t still wins."""
    ql = q.lower()
    matches = []
    for t, hints in TYPE_HINTS.items():
        if any(h in ql for h in hints):
            matches.append(t)
    return matches[0] if matches else None


def strip_type_terms(q):
    """Remove explicit type words before semantic scoring so "database MCP" scores database."""
    out = q
    for hints in TYPE_HINTS.values():
        for h in hints:
            out = re.sub(re.escape(h), " ", out, flags=re.I)
    return re.sub(r"\s+", " ", out).strip() or q


def score_all(q, catalog, only_type=None, profiles=None, usage=None):
    profiles = profiles or {}
    usage = usage or {}
    en, segs, grams, ex = tokenize(q)
    res = []
    for t in TYPES:
        if only_type and t != only_type:
            continue
        for it in catalog.get(t, []):
            name = (it.get("name") or "").lower()
            cat = (it.get("category") or "").lower()
            desc = (it.get("description") or "").lower()
            sc, hits = 0.0, 0
            for words, w in ((en, 1), (grams, 1), (segs, 1.5), (ex, 0.8)):
                for tok in words:
                    h = (5 if tok in name else 0) + (2 if tok in cat else 0) + (1 if tok in desc else 0)
                    if h:
                        sc += h * w
                        hits += 1
            if sc <= 0:
                continue
            sc += hits * 2
            if it.get("mine"):
                sc *= 1.5
            sc += math.log10((it.get("downloads") or 0) + 1) * 0.3
            sc += math.log10((usage.get(it.get("path")) or 0) + 1) * 0.4
            sc += profile_bonus(profile_for(t, it, profiles))
            res.append((sc, t, it))
    res.sort(key=lambda x: -x[0])
    return res


def install_cmd(t, it):
    if it.get("install"):
        return str(it["install"])
    p = re.sub(r"\.(md|json)$", "", it.get("path") or it.get("name") or "")
    return f"npx claude-code-templates@latest {FLAGS[t]} {p} --yes"


def use_instruction(t, it, profile=None):
    status = ((profile or {}).get("how_to_use") or {}).get("status")
    if it.get("mine"):
        if status == "local_installed":
            return "本地已装：直接按当前 Codex skill 路由调用；不输出公开安装命令"
        return "私有共享通道：需仓库/共享权限后再安装；不输出公开安装命令"
    return install_cmd(t, it)


