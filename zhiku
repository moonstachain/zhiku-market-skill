def _routing_canonical_id(t, it, profiles):
    if t != "skills":
        return ""
    profile = profile_for(t, it, profiles)
    canonical_id = str(
        profile.get("canonical_id") or it.get("canonical_id") or ""
    )
    if SKILL_CANONICAL_ID.fullmatch(canonical_id):
        return canonical_id
    name = re.sub(
        r"[^a-z0-9]+",
        "-",
        str(it.get("name") or "").strip().lower(),
    ).strip("-")
    fallback = f"zk:skill:{name}" if name else ""
    return fallback if SKILL_CANONICAL_ID.fullmatch(fallback) else ""


def write_routing_receipts(query, hits, profiles, evolution_note=None):
    """Persist privacy-minimized local recommendation exposure receipts.

    The query and task identifiers are hashed and never stored. A caller may
    provide ``ZHIKU_USAGE_EVENT_ID`` to make retries of the same routing event
    idempotent; otherwise each CLI invocation is a new recommendation event.

    ``evolution_note`` is the optional third ring of the SOUL evidence loop
    (no Evolution Note -> no Done): a short reusable lesson from this routing
    event. It is written into every receipt of the event when provided and
    omitted otherwise. Returns the receipt file paths written (or already
    present, for idempotent retries), so callers can honestly verify evidence
    backflow per candidate from the receipts on disk.
    """
    if os.environ.get("ZHIKU_NO_LOCAL_USAGE_RECEIPTS") == "1":
        return []
    event_source = os.environ.get("ZHIKU_USAGE_EVENT_ID") or (
        f"route:{utc_now()}:{os.getpid()}:{uuid.uuid4().hex}"
    )
    task_source = os.environ.get("ZHIKU_TASK_ID") or re.sub(
        r"\s+", " ", str(query or "").strip().lower()
    )
    task_hash = hashlib.sha256(task_source.encode("utf-8")).hexdigest()[:16]
    occurred_at = utc_now()
    root = _routing_receipt_root()
    written = []
    for rank, (_, t, it) in enumerate(hits, 1):
        canonical_id = _routing_canonical_id(t, it, profiles)
        if not canonical_id:
            continue
        event_hash = hashlib.sha256(
            f"{event_source}|{canonical_id}".encode("utf-8")
        ).hexdigest()[:16]
        receipt_key = json.dumps(
            {
                "canonical_id": canonical_id,
                "client": "zhiku_cli",
                "event_hash": event_hash,
            },
            sort_keys=True,
            separators=(",", ":"),
        )
        receipt_id = "zkur2-" + hashlib.sha256(
            receipt_key.encode("utf-8")
        ).hexdigest()[:16]
        receipt = {
            "schema": "skill_usage_receipt_v2",
            "receipt_id": receipt_id,
            "occurred_at": occurred_at,
            "canonical_id": canonical_id,
            "client": "zhiku_cli",
            "event_hash": event_hash,
            "task_hash": task_hash,
            "task_type": "skill-routing",
            "event": "recommended",
            "note": f"router recommendation rank={rank}",
            "duration_ms": None,
            "raw_conversation_stored": False,
        }
        if evolution_note:
            receipt["evolution_note"] = str(evolution_note)[:500]
        target = root / f"{receipt_id}.json"
        try:
            root.mkdir(parents=True, exist_ok=True)
            with target.open("x", encoding="utf-8") as stream:
                json.dump(receipt, stream, ensure_ascii=False, indent=2)
                stream.write("\n")
        except FileExistsError:
            # Idempotent retry: the receipt already exists on disk, so the
            # evidence backflow for this candidate is still real.
            written.append(str(target))
            continue
        except OSError:
            continue
        written.append(str(target))
    return written


