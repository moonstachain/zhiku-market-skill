def profile_bonus(profile):
    """Governance-aware tie-breaker.

    Semantic match must dominate routing. Local availability, validation, and
    usage make a close candidate better; they should not lift a weak semantic
    hit above a clearly relevant remote component.
    """
    if not profile:
        return 0.0
    bonus = 0.0
    status = ((profile.get("how_to_use") or {}).get("status") or "")
    if status == "local_installed":
        bonus += 2.0
    elif status == "private_channel":
        bonus += 0.6
    usage = profile.get("usage") or {}
    calls = usage.get("local_calls") or 0
    try:
        bonus += min(1.5, float(calls) * 0.15)
    except Exception:
        pass
    validation = profile.get("validation") or {}
    if validation.get("state") in ("validated", "pass", "green"):
        bonus += 1.5
    risk = profile.get("risk_signals") or []
    if isinstance(risk, list):
        bonus -= min(2.0, len(risk) * 0.5)
    elif risk:
        bonus -= 0.5
    return bonus


def confidence_for(score, profile):
    base = min(0.88, 0.35 + float(score) / 120.0)
    if profile:
        rc = profile.get("routing_confidence")
        if isinstance(rc, (int, float)):
            base = (base + float(rc)) / 2
    return round(max(0.05, min(0.98, base)), 2)


