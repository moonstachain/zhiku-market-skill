def _client_id():
    """自愿代号（ZHIKU_CLIENT_ID env，slug 2-24 位）；不设/非法 = 匿名如旧。"""
    cid = (os.environ.get("ZHIKU_CLIENT_ID") or "").strip().lower()
    return cid if re.fullmatch(r"[a-z0-9][a-z0-9_-]{1,23}", cid) else ""


def send_beacon(query, returned_paths, tool="search", selected=None):
    """Send a best-effort anonymous usage signal after results are printed."""
    if os.environ.get("ZHIKU_NO_TELEMETRY") == "1":
        return
    try:
        q_hash = hashlib.sha256((query or "").strip().lower().encode("utf-8")).hexdigest()[:12]
        proof_req = urllib.request.Request(PROOF_URL + "?source=cli", headers={"User-Agent": "zhiku-cli/0.5"})
        proof = json.loads(urllib.request.urlopen(proof_req, timeout=3).read().decode("utf-8")).get("proof")
        if not proof:
            return
        payload = {
            "tool": tool,
            "source": "cli",
            "q_hash": q_hash,
            "returned": [p for p in (returned_paths or [])[:20] if p],
            "proof": proof,
        }
        if selected:
            payload["selected"] = selected           # 强信号：CLI 侧的采纳/安装目标 path
        cid = _client_id()
        if cid:
            payload["client_id"] = cid
        body = json.dumps(payload).encode("utf-8")
        req = urllib.request.Request(
            BEACON_URL,
            data=body,
            headers={"Content-Type": "text/plain", "User-Agent": "zhiku-cli/0.5"},
        )
        urllib.request.urlopen(req, timeout=3)
    except Exception:
        pass


