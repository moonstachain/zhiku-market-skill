    status = ((profile or {}).get("how_to_use") or {}).get("status") or ("private_channel" if it.get("mine") else "remote_install")
    if t in ("hooks", "settings") or risk:
        return "govern"
    if "dashboard" in (it.get("description") or "").lower() or "cockpit" in (it.get("description") or "").lower():
        return "cockpit"
    if status == "local_installed":
        return "route"
    return "route"


def confidence_grade(profile):
    """Dual-track confidence label aligned with canon: 🟢 direct vs 🟡 inferred.

    🟢 (直证) requires observed evidence on the profile: a green validation
    state or recorded local usage. Everything else is 🟡 (推断). The 0-1
    decimal ranks candidates; the grade governs decision display. Never
    present a bare decimal behind a green badge without this check.
    """
    profile = profile or {}
    validation = ((profile.get("validation") or {}).get("state") or "")
    usage = profile.get("usage") or {}
    try:
        observed = float(usage.get("local_calls") or 0) > 0
    except (TypeError, ValueError):
        observed = False
    if validation in ("validated", "pass", "green") or observed:
        return "🟢"
    return "🟡"


# Canonical Three Seals (yuanli-os-greenbook A01/A07): recursive evolution /
# skill commander (先 search 再 call) / human friendliness. "Global optimum"
# is NOT a seal; it remains the internal ordering principle of route mode.
GLOBAL_OPTIMUM_ORDERING_NOTE = (
    "全局最优不是三法印；它是 route 模式内部的排序原则："
    "最小可靠路由优先，本地可用 > 远程安装 > 无证据不推荐。"
)
_GATE_WORDS = ("人工", "审批", "确认", "权限", "approval", "review")


def _seal(status, detail):
    return {"status": status, "detail": detail}


def three_seals_for(t, it, profile, context=None):
    """Per-candidate real check of the canonical Three Seals.

    ``context`` records what the caller actually did for this recommendation:
      - ``search_performed``: {"catalog": bool, "local_profiles": bool} —
        whether the catalog / local profiles were really searched first;
      - ``receipts_written``: iterable of canonical ids that received a
        usage receipt in this routing event;
      - ``canonical_id``: this candidate's canonical id;
      - ``next_step``: the exact next-step text emitted to the user.

    Missing context means unverified, which reports ``warn`` — fail-closed,
    never a decorative green template. Returns one dict per seal with
    ``status`` in {"pass", "warn"} plus an ``overall`` rollup.
    """
    context = context or {}
    profile = profile or {}
    status = ((profile.get("how_to_use") or {}).get("status")
              or ("private_channel" if it.get("mine") else "remote_install"))
    validation = ((profile.get("validation") or {}).get("state") or "unknown")
    risk = profile.get("risk_signals") or []
    usage = profile.get("usage") or {}
    try:
        local_calls = float(usage.get("local_calls") or 0)
    except (TypeError, ValueError):
        local_calls = 0.0

    # Seal 2 — skill commander: search before call.
    search = context.get("search_performed")
    if isinstance(search, dict):
        catalog_searched = bool(search.get("catalog"))
        profiles_searched = bool(search.get("local_profiles"))
        if catalog_searched or profiles_searched:
            commander = _seal(
                "pass",
                f"推荐前已检索：目录={'是' if catalog_searched else '否'}，"
                f"本地 profiles={'是' if profiles_searched else '否'}（先 search 再 call）",
            )
        else:
            commander = _seal("warn", "已记录检索上下文但目录与本地 profiles 均未命中检索；先 search 再 call 未达成")
    else:
        commander = _seal("warn", "无检索证据记录；无法核实是否先 search 再 call")

    # Seal 1 — recursive evolution: evidence backflow for this candidate.
    canonical_id = str(context.get("canonical_id") or "")
    receipt_ids = set(context.get("receipts_written") or [])
    if canonical_id and canonical_id in receipt_ids:
        evolution = _seal("pass", f"本次路由已为 {canonical_id} 写入 usage receipt，证据回流成立")
    elif validation in ("validated", "pass", "green"):
        evolution = _seal("pass", f"profile 已有验证证据（state={validation}），使用后应刷新")
    elif local_calls > 0:
        evolution = _seal("pass", f"profile 已有本地调用记录（{int(local_calls)} 次），使用后应刷新")
    else:
        evolution = _seal("warn", "本候选无 receipt/验证/用量回流；按 internal-dry-run 对待，禁止呈现为已验证")

    # Seal 3 — human friendliness: only human-decision items, gates intact.
    needs_gate = (
        t in ("hooks", "settings")
        or status == "private_channel"
        or (bool(risk) and status != "local_installed")
    )
    next_step = str(context.get("next_step") or "")
    if needs_gate:
        if next_step and any(word in next_step for word in _GATE_WORDS):
            friendly = _seal("pass", f"高暴露面（{status}）已挂人工门，仅呈现需人决策项")
        else:
            friendly = _seal("warn", "高暴露面候选的对外文案未核实人工门；不得直接呈现安装/执行指令")
    else:
        burden = "本地已装，直接调用" if status == "local_installed" else "远程候选，安装前给出一项人工确认"
        friendly = _seal("pass", f"低负担路由：{burden}；无不可逆外部写入")

    seals = {
        "recursive_evolution": evolution,
        "skill_commander": commander,
        "human_friendliness": friendly,
    }
    seals["overall"] = (
        "pass"
        if all(seal["status"] == "pass" for seal in seals.values())
        else "warn"
    )
    return seals


def backwrite_for(t, it, profile, context=None):
    """Required MAX output field 回流 (backwrite): where evidence must flow.

    The contract is fail-closed: the field is always present, and when no
    backwrite target exists it says so explicitly with a reason instead of
    omitting the field or inventing one.
    """
    context = context or {}
    profile = profile or {}
    canonical_id = str(context.get("canonical_id") or "")
    receipt_ids = set(context.get("receipts_written") or [])
    if canonical_id and canonical_id in receipt_ids:
        return {
            "target": "usage_receipt",
            "reason": f"本次路由已为 {canonical_id} 写入 skill_usage_receipt_v2",
        }
    validation = ((profile.get("validation") or {}).get("state") or "")
    usage = profile.get("usage") or {}
    try:
        local_calls = float(usage.get("local_calls") or 0)
    except (TypeError, ValueError):
        local_calls = 0.0
    if validation in ("validated", "pass", "green") or local_calls > 0:
        return {
            "target": "profile",
            "reason": "profile 已有验证/用量证据；本次使用结果应回流刷新该 profile",
        }
    if t in ("hooks", "settings") or (profile.get("risk_signals") or []):
        return {
            "target": "risk_item",
            "reason": "高暴露面且零用量证据；安装前应在风险/决策板登记一项人工复核",
        }
    return {
        "target": "none",
        "reason": "无回流目标：候选无 profile 验证、无用量、本次未写入 receipt；先完成真实检索与试用再推荐",
    }


