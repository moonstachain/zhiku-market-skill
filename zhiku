def normalize_recipe(recipe):
    if not isinstance(recipe, dict):
        raise ValueError("operation_recipe_v1 must be a JSON object")
    out = dict(recipe)
    out.setdefault("schema", "operation_recipe_v1")
    out.setdefault("executor", "ego-browser")
    out.setdefault("permission_level", "inspect")
    out.setdefault("planned_steps", [])
    out.setdefault("checkpoints", [])
    out.setdefault("rollback_note", "No external write should be made without a fresh human gate.")
    out.setdefault("risk_tags", [])
    out.setdefault("component_path", None)
    missing = [k for k in ("intent", "target_url") if not out.get(k)]
    if missing:
        raise ValueError("recipe missing required field(s): " + ", ".join(missing))
    if out.get("executor") != "ego-browser":
        raise ValueError("only executor=ego-browser is supported in v1")
    if out.get("permission_level") not in PERMISSION_LEVELS:
        raise ValueError("permission_level must be one of: " + ", ".join(PERMISSION_LEVELS))
    if not re.match(r"^https?://", str(out.get("target_url"))):
        raise ValueError("target_url must be an http(s) URL")
    if not isinstance(out.get("planned_steps"), list):
        raise ValueError("planned_steps must be a list")
    if not isinstance(out.get("checkpoints"), list):
        raise ValueError("checkpoints must be a list")
    if not isinstance(out.get("risk_tags"), list):
        raise ValueError("risk_tags must be a list")
    return out


def _sensitive_hash(value):
    return hashlib.sha256(str(value or "").encode("utf-8")).hexdigest()


def _safe_url_origin(value):
    try:
        parsed = urllib.parse.urlsplit(str(value or ""))
        return f"{parsed.scheme}://{parsed.netloc}" if parsed.scheme and parsed.netloc else "redacted"
    except Exception:
        return "redacted"


def receipt_safe_recipe(recipe):
    safe = dict(recipe)
    if safe.get("receipt_redaction") != "wechat_agent":
        return safe
    target = safe.get("target_url")
    safe["target_url"] = _safe_url_origin(target)
    safe["target_url_hash"] = _sensitive_hash(target)
    fields = safe.pop("draft_fields", [])
    if fields:
        safe["draft_field_hashes"] = [
            {"selector_hash": _sensitive_hash(field.get("selector")), "value_hash": _sensitive_hash(field.get("value"))}
            for field in fields if isinstance(field, dict)
        ]
    return safe


def redact_wechat_operation_receipt(receipt):
    if (receipt.get("recipe") or {}).get("receipt_redaction") != "wechat_agent":
        return receipt
    receipt["target_url_hash"] = _sensitive_hash(receipt.get("target_url"))
    receipt["target_url"] = _safe_url_origin(receipt.get("target_url"))
    receipt["observations"] = [
        {
            "type": str(row.get("type") or "observation"),
            "value_hash": _sensitive_hash(row.get("value")),
            "value_length": len(str(row.get("value") or "")),
        }
        for row in (receipt.get("observations") or []) if isinstance(row, dict)
    ]
    cleaned_actions = []
    for row in receipt.get("actions_taken") or []:
        if not isinstance(row, dict):
            continue
        clean = {key: value for key, value in row.items() if key not in {"selector", "value"}}
        if row.get("selector"):
            clean["selector_hash"] = _sensitive_hash(row["selector"])
        cleaned_actions.append(clean)
    receipt["actions_taken"] = cleaned_actions
    return receipt


