    for s, t, it in hits:
        star = " ★私有(需仓权限)" if it.get("mine") else ""
        p = profile_for(t, it, profiles)
        status = ((p.get("how_to_use") or {}).get("status") or ("private_channel" if it.get("mine") else "remote_install"))
        risk = p.get("risk_signals") or []
        desc = re.sub(r"\s+", " ", it.get("description") or "").strip()[:100]
        print(f"  {it.get('name')}  〔{t}·{it.get('category','—')}·{status}〕{star}")
        print(f"    {desc}")
        for ln in deep_text_lines(t, it, deepmaps, want_deep):
            print(ln)
        if risk:
            print("    profile 风险: " + ", ".join(risk if isinstance(risk, list) else [str(risk)]))
        if max_mode:
            print(f"    MAX 置信度: {confidence_for(s, p):.2f} · 模式: {max_mode_for(t, it, p)} · tier: {p.get('max_recommendation_tier', 'unknown')}")
            seals = three_seals_for(t, it, p)
            print("    三法印:")
            print("      递归进化: " + seals["recursive_evolution"])
            print("      全局最优: " + seals["global_optimum"])
            print("      人类友好: " + seals["human_friendliness"])
            print("    下一步: " + next_step_for(t, it, p))
        instruction = use_instruction(t, it, p)
        if it.get("mine"):
            print(f"    {instruction}\n")
        else:
            print(f"    $ {instruction}\n")
    send_beacon(query, [it.get("path") for _, _, it in hits])


