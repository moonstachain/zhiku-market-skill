def deep_record(t, it, deepmaps):
    if it.get("mine"):
        return None
    record = (deepmaps.get(t) or {}).get(it.get("path"))
    if record:
        return record
    try:
        req = urllib.request.Request(
            COMPONENT_ENDPOINT + (it.get("path") or ""),
            headers={"User-Agent": "zhiku-cli/0.4"},
        )
        full = json.loads(urllib.request.urlopen(req, timeout=3).read().decode("utf-8"))
        return full.get("deep") or None
    except Exception:
        return None


def deep_text_lines(t, it, deepmaps, want_deep):
    """深度索引输出行: 不带 --deep 时只给 mcps 附「需 env:」; 带 --deep 时全量。"""
    if it.get("mine"):
        return ["    深度: 私有组件无公开深度信息（安装需 yuanli-os-starter 仓权限）"] if want_deep else []
    r = deep_record(t, it, deepmaps)
    if not r:
        return []
    out = []
    ek = r.get("env_required") or r.get("env_keys")
    if ek and (want_deep or t == "mcps"):
        out.append("    需 env: " + ", ".join(ek))
    if want_deep:
        if r.get("runner"):
            out.append("    运行方式: " + str(r["runner"]))
        if r.get("deps"):
            out.append("    依赖: " + ", ".join(r["deps"]))
        if r.get("allowed_tools"):
            out.append("    工具: " + r["allowed_tools"])
        if r.get("triggers"):
            out.append("    触发: " + r["triggers"][0])
        if r.get("usage"):
            out.append("    用法: " + r["usage"][0])
        if r.get("events"):
            out.append("    事件: " + ", ".join(r["events"]))
        if r.get("risk"):
            out.append("    风险信号: " + ", ".join(r["risk"]))
    return out


def normalize_governance_aliases(args):
    """Map human-facing governance commands onto the private control plane."""
    if len(args) < 2:
        return args
    aliases = {
        ("task", "contract"): "task-contract",
        ("route", "plan"): "route-plan",
        ("route", "verify"): "route-verify",
        ("route", "human-review"): "route-human-review",
        ("route", "human-review-record"): "route-human-review-record",
        ("route", "human-review-import"): "route-human-review-import",
        ("route", "shadow-record"): "route-shadow-record",
        ("route", "shadow-status"): "route-shadow-status",
        ("route", "shadow-readiness"): "route-shadow-readiness",
        ("agent", "gap"): "agent-gap",
        ("skill", "rerank"): "skill-rerank",
        ("adapter", "audit"): "adapter-audit",
        ("hook", "audit"): "hook-audit",
        ("instrumentation", "audit"): "instrumentation-audit",
        ("instrumentation", "plan"): "instrumentation-plan",
        ("instrumentation", "activate"): "instrumentation-activate",
        ("ecology", "report"): "ecology-report",
    }
    command = aliases.get((args[0], args[1]))
    return ["skill", command, *args[2:]] if command else args


